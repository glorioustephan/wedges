{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_DOCSEARCH_APP_ID",
        "NEXT_PUBLIC_DOCSEARCH_API_KEY",
        "NEXT_PUBLIC_DOCSEARCH_INDEX_NAME"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "parse-catalog": {
      "dependsOn": [],
      "outputs": [
        "catalog/components.json",
        "catalog/tokens.json",
        "catalog/patterns.json",
        "catalog/categories.json",
        "catalog/manifest.json",
        "catalog/catalog.schema.json"
      ]
    },
    "build-db": {
      "dependsOn": ["parse-catalog"],
      "outputs": ["catalog/tomo-ui.sqlite", "catalog/build-report.json"]
    },
    "rebuild": {
      "dependsOn": ["parse-catalog", "build-db"],
      "outputs": ["catalog/**"]
    },
    "benchmark": {
      "dependsOn": ["build-db"],
      "outputs": ["benchmarks/results.json"]
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": []
    },
    "lint": {
      "cache": false,
      "outputs": []
    },
    "lint:fix": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "NEXT_PUBLIC_DOCSEARCH_APP_ID",
        "NEXT_PUBLIC_DOCSEARCH_API_KEY",
        "NEXT_PUBLIC_DOCSEARCH_INDEX_NAME",
        "WEBFLOW_API_KEY",
        "WEBFLOW_BLOG_ID",
        "WEBFLOW_CASE_STUDIES_ID",
        "NODE_ENV",
        "NEXT_PUBLIC_VERCEL_ENV"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}
